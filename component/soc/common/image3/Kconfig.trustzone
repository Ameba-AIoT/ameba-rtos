# Common TrustZone Kconfig for Ameba SoCs
# This file provides unified TrustZone configuration across different ICs

menu "CONFIG TrustZone"

config TRUSTZONE
    bool "Enable TrustZone"
config TRUSTZONE_EN
    depends on TRUSTZONE
    bool
    default y

if TRUSTZONE
    config TRUSTZONE_MBEDTLS
        bool "Enable MbedTLS in Image3"
        default n
        help
            Enable MbedTLS library in TrustZone secure image (Image3).
            When enabled, CONFIG_TZ_S_SIZE default will be increased to 128K.
endif

endmenu
