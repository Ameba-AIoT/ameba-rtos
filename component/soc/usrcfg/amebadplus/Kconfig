menu "CONFIG User Config"

menu "Flash Layout Configuration"

# Boot Manifest(4K) + KM4 Bootloader(252K)
comment "BOOT Offset: 0x8000000 (fixed)"

config FLASH_BOOT_OFFSET
    hex
    default 0x8000000

config FLASH_BOOT_SIZE
    hex "BOOT Size"
    default 0x14000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 Application OTA1 + RDP IMG OTA1
config FLASH_OTA1_OFFSET
    hex "APP OTA1 Offset"
    default 0x8014000

config FLASH_OTA1_SIZE
    hex "APP OTA1 Size"
    default 0x1EC000

# Boot Manifest(4K) + KM4 Bootloader(252K) OTA
config FLASH_BOOT_OTA2_OFFSET
    hex "BOOT OTA2 Offset"
    default 0x8200000

config FLASH_BOOT_OTA2_SIZE
    hex "BOOT OTA2 Size"
    default 0x14000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 Application OTA2 + RDP IMG OTA2
config FLASH_OTA2_OFFSET
    hex "APP OTA2 Offset"
    default 0x8214000

config FLASH_OTA2_SIZE
    hex "APP OTA2 Size"
    default 0x1C9000

# VFS region 1 (512K)
config FLASH_VFS1_OFFSET
    hex "VFS1 Offset"
    default 0x83E0000

config FLASH_VFS1_SIZE
    hex "VFS1 Size"
    default 0x20000

# VFS region 2
config FLASH_VFS2_OFFSET
    hex "VFS2 Offset"
    default 0xFFFFFFFF

config FLASH_VFS2_SIZE
    hex "VFS2 Size"
    default 0

# reserve for user
config FLASH_USER_OFFSET
    hex "USER Offset"
    default 0xFFFFFFFF

config FLASH_USER_SIZE
    hex "USER Size"
    default 0

endmenu

menu "Boot Configuration"

config LOGUART_AGG_EN
    bool "Enable Loguart AGG"
    default n
    help
        Enable or disable Loguart log aggregation (Boot_Agg_En).
        If the output character sequence of the serial port tool is
        disordered, enable this option according to the chip ID.

endmenu

menu "Clock Configuration"

choice
    prompt "SoC Clock Config"
    default CLKCFG_USB_0P9_480M
    help
        Select the SoC clock configuration. The leading [N] is the index into
        SocClk_Info[] in ameba_bootcfg.c (assigned to Boot_SocClk_Info_Idx via
        CONFIG_CLKCFG_IDX). The bootloader still validates the choice against the
        chip package (SiP Psram / No Psram); an unsupported combination will
        assert at boot.
        When USB device is enabled, only the 480MHz option (PLL is an integer
        multiple of 48MHz) is available.

config CLKCFG_PSRAM_0P9_524M
    bool "[0] SiP Psram, 0.9V, PLL 524MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_PSRAM_0P9_392M
    bool "[1] SiP Psram, 0.9V, PLL 392MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_PSRAM_1P0_334M
    bool "[2] SiP Psram, 1.0V, PLL 334MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_NOPSRAM_0P9_512M
    bool "[3] SiP Flash / single die, 0.9V, PLL 512MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_NOPSRAM_0P9_400M
    bool "[4] SiP Flash / single die, 0.9V, PLL 400MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_NOPSRAM_1P0_334M
    bool "[5] SiP Flash / single die, 1.0V, PLL 334MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_USB_0P9_480M
    bool "[6] USB (48M-multiple), 0.9V, PLL 480MHz"

config CLKCFG_AUDIO_1P0_677M
    bool "[7] Audio, 1.0V, PLL 677.376MHz"
    depends on !USB_DEVICE_EN

config CLKCFG_AUDIO_1P0_688M
    bool "[8] Audio, 1.0V, PLL 688.128MHz"
    depends on !USB_DEVICE_EN

endchoice

config CLKCFG_IDX
    int
    default 0 if CLKCFG_PSRAM_0P9_524M
    default 1 if CLKCFG_PSRAM_0P9_392M
    default 2 if CLKCFG_PSRAM_1P0_334M
    default 3 if CLKCFG_NOPSRAM_0P9_512M
    default 4 if CLKCFG_NOPSRAM_0P9_400M
    default 5 if CLKCFG_NOPSRAM_1P0_334M
    default 7 if CLKCFG_AUDIO_1P0_677M
    default 8 if CLKCFG_AUDIO_1P0_688M
    default 6

endmenu

menu "RAM Layout Configuration"

# TrustZone secure image (Image3) size. For SoCs without PSRAM this region may
# live in SRAM, so it is a general RAM-layout parameter, configured per IC.
config TZ_S_SIZE
    int "TrustZone Secure Image Size (KB)"
    depends on TRUSTZONE
    default 128 if TRUSTZONE_MBEDTLS
    default 64
    help
        Size of TrustZone secure image (Image3) in KB.
        Default 64KB, or 128KB when MbedTLS is enabled.

config PSRAM_KM0_IMG2_KB
    int "KM0 PSRAM image2 size (KB)"
    depends on IMG2_PSRAM || DATA_HEAP_PSRAM
    range 64 2048
    default 876
    help
        Size of the NP(KM0) PSRAM image2 segment. Only meaningful when the NP
        core places code (IMG2_PSRAM) or data/heap (DATA_HEAP_PSRAM) in PSRAM.
        Otherwise the segment collapses to 0 and all non-secure PSRAM goes to
        the AP(KM4) heap.

endmenu

endmenu
