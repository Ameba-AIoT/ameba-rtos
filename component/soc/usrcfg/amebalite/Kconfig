menu "CONFIG User Config"

menu "Flash Layout Configuration"

# Boot Manifest(4K) + KM4 Bootloader(252K)
comment "BOOT Offset: 0x8000000 (fixed)"

config FLASH_BOOT_OFFSET
    hex
    default 0x8000000

config FLASH_BOOT_SIZE
    hex "BOOT Size"
    default 0x14000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 & CA32 Application OTA1 + RDP IMG OTA1
config FLASH_OTA1_OFFSET
    hex "APP OTA1 Offset"
    default 0x8014000

config FLASH_OTA1_SIZE
    hex "APP OTA1 Size"
    default 0x1EC000

# Boot Manifest(4K) + KM4 Bootloader(252K) OTA
config FLASH_BOOT_OTA2_OFFSET
    hex "BOOT OTA2 Offset"
    default 0x8200000

config FLASH_BOOT_OTA2_SIZE
    hex "BOOT OTA2 Size"
    default 0x14000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 & CA32 Application OTA2 + RDP IMG OTA2
config FLASH_OTA2_OFFSET
    hex "APP OTA2 Offset"
    default 0x8214000

config FLASH_OTA2_SIZE
    hex "APP OTA2 Size"
    default 0x1C9000

# VFS region 1 (512K)
config FLASH_VFS1_OFFSET
    hex "VFS1 Offset"
    default 0x083E0000

config FLASH_VFS1_SIZE
    hex "VFS1 Size"
    default 0x20000

# Manifest(4K) + DSP IMG
config FLASH_DSP_OFFSET
    hex "DSP Offset"
    default 0x08400000

config FLASH_DSP_SIZE
    hex "DSP Size" if DSP_EN
    default 0x300000 if DSP_EN
    default 0

# VFS region 2
config FLASH_VFS2_OFFSET
    hex "VFS2 Offset"
    default 0xFFFFFFFF

config FLASH_VFS2_SIZE
    hex "VFS2 Size"
    default 0

# reserve for user
config FLASH_USER_OFFSET
    hex "USER Offset"
    default 0xFFFFFFFF

config FLASH_USER_SIZE
    hex "USER Size"
    default 0

endmenu

menu "Boot Configuration"

config LOGUART_AGG_EN
    bool "Enable Loguart AGG"
    default n
    help
        Enable or disable Loguart log aggregation (Boot_Agg_En).
        If the output character sequence of the serial port tool is
        disordered, enable this option according to the chip ID.

endmenu

menu "Clock Configuration"

choice
    prompt "SoC Clock Config"
    default CLKCFG_AUTO
    help
        Select the SoC clock configuration. AUTO (CONFIG_CLKCFG_IDX 0xFF) lets the
        bootloader pick the clock/voltage level at runtime according to the PSRAM
        clock limit (recommended). For the fixed levels, the leading [N] is the
        index into SocClk_Info[] in ameba_bootcfg.c.

config CLKCFG_AUTO
    bool "[auto] Auto by PSRAM clock (0xFF)"

config CLKCFG_0P9_PSRAM166
    bool "[0] 0.9V, PSRAM 166MHz"

config CLKCFG_1P0_PSRAM166
    bool "[1] 1.0V, PSRAM 166MHz"

config CLKCFG_1P0_PSRAM200
    bool "[2] 1.0V, PSRAM 200MHz"

config CLKCFG_1P0_PSRAM250
    bool "[3] 1.0V, PSRAM 250MHz"

endchoice

config CLKCFG_IDX
    int
    default 0 if CLKCFG_0P9_PSRAM166
    default 1 if CLKCFG_1P0_PSRAM166
    default 2 if CLKCFG_1P0_PSRAM200
    default 3 if CLKCFG_1P0_PSRAM250
    default 255

endmenu

endmenu
