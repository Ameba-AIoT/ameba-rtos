menu "CONFIG User Config"

menu "Flash Layout Configuration"

# Boot Manifest(4K) + KM4 Bootloader(252K)
comment "BOOT Offset: 0x8000000 (fixed)"

config FLASH_BOOT_OFFSET
    hex
    default 0x8000000

config FLASH_BOOT_SIZE
    hex "BOOT Size"
    default 0x40000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 Application OTA1 + RDP IMG OTA1
config FLASH_OTA1_OFFSET
    hex "APP OTA1 Offset"
    default 0x8040000

config FLASH_OTA1_SIZE
    hex "APP OTA1 Size"
    default 0x180000

# Boot Manifest(4K) + KM4 Bootloader(252K) OTA
config FLASH_BOOT_OTA2_OFFSET
    hex "BOOT OTA2 Offset"
    default 0x81C0000

config FLASH_BOOT_OTA2_SIZE
    hex "BOOT OTA2 Size"
    default 0x40000

# Certificate(4K) + Manifest(4K) + KM0 & KM4 Application OTA2 + RDP IMG OTA2
config FLASH_OTA2_OFFSET
    hex "APP OTA2 Offset"
    default 0x8200000

config FLASH_OTA2_SIZE
    hex "APP OTA2 Size"
    default 0x180000

# VFS region 1 (512K)
config FLASH_VFS1_OFFSET
    hex "VFS1 Offset"
    default 0x83C0000

config FLASH_VFS1_SIZE
    hex "VFS1 Size"
    default 0x80000

# VFS region 2
config FLASH_VFS2_OFFSET
    hex "VFS2 Offset"
    default 0xFFFFFFFF

config FLASH_VFS2_SIZE
    hex "VFS2 Size"
    default 0

# reserve for user
config FLASH_USER_OFFSET
    hex "USER Offset"
    default 0xFFFFFFFF

config FLASH_USER_SIZE
    hex "USER Size"
    default 0

endmenu

menu "Boot Configuration"

config LOGUART_AGG_EN
    bool "Enable Loguart AGG"
    default n
    help
        Enable or disable Loguart log aggregation (Boot_Agg_En).
        If the output character sequence of the serial port tool is
        disordered, enable this option according to the chip ID.

endmenu

menu "Clock Configuration"

choice
    prompt "SoC Clock Config"
    default CLKCFG_0P9_RMII_USB
    help
        Select the SoC clock configuration. The leading [N] is the index into
        SocClk_Info[] in ameba_bootcfg.c (assigned to Boot_SocClk_Info_Idx via
        CONFIG_CLKCFG_IDX).

config CLKCFG_0P9_NO_SYSPLL
    bool "[0] 0.9V, no SysPLL, CPU 240MHz (low power)"

config CLKCFG_0P9_RMII_USB
    bool "[1] 0.9V, RMII/USB, CPU 240MHz"

config CLKCFG_0P9_AUDIO98P304M_USB
    bool "[2] 0.9V, Audio(98.304MHz)/USB, CPU 240MHz"

config CLKCFG_0P9_AUDIO45P1584M_USB
    bool "[3] 0.9V, Audio(45.1584MHz)/USB, CPU 240MHz"

config CLKCFG_0P9_AUDIO_RMII
    bool "[4] 0.9V, Audio/RMII, CPU 266.7MHz"

config CLKCFG_1P0_RMII_USB
    bool "[5] 1.0V, RMII/USB, CPU 320MHz"

config CLKCFG_1P0_AUDIO_USB
    bool "[6] 1.0V, Audio/USB, CPU 320MHz"

config CLKCFG_1P0_AUDIO_RMII
    bool "[7] 1.0V, Audio/RMII, CPU 333.3MHz"

endchoice

config CLKCFG_IDX
    int
    default 0 if CLKCFG_0P9_NO_SYSPLL
    default 1 if CLKCFG_0P9_RMII_USB
    default 2 if CLKCFG_0P9_AUDIO98P304M_USB
    default 3 if CLKCFG_0P9_AUDIO45P1584M_USB
    default 4 if CLKCFG_0P9_AUDIO_RMII
    default 5 if CLKCFG_1P0_RMII_USB
    default 6 if CLKCFG_1P0_AUDIO_USB
    default 7 if CLKCFG_1P0_AUDIO_RMII
    default 1

endmenu

endmenu
