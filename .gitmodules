#
# All submodules use relative URLs.
#

[submodule "component/audio"]
	path = component/audio
	url = ../ameba-audio.git
	branch = master

[submodule "component/ui"]
	path = component/ui
	url = ../ameba-ui.git
	branch = master

[submodule "component/aivoice"]
	path = component/aivoice
	url = ../ameba-aivoice.git
	branch = main

[submodule "component/tflite_micro"]
	path = component/tflite_micro
	url = ../ameba-tflite-micro.git
	branch = main
[submodule "component/application/speechmind"]
	path = component/application/speechmind
	url = ../speechmind.git
	branch = master
